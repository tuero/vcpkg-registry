{
  "name": "libpolicyts",
  "version": "1.7.6",
  "maintainers": "Jake Tuero <tuero@ualberta.ca>",
  "description": "A C++23 library for policy tree search algorithms and auxiliary utilities.",
  "homepage": "https://github.com/tuero/libpolicyts",
  "dependencies": [
    "abseil",
    "boulderdash",
    "craftworld",
    "igraph",
    "libleidenalg",
    "nlohmann-json",
    "sokoban",
    "spdlog",
    "tsp",
    {
      "name": "vcpkg-cmake",
      "host": true
    },
    {
      "name": "vcpkg-cmake-config",
      "host": true
    }
  ],
  "features": {
    "environment": {
      "description": "Build environment wrappers"
    },
    "torch": {
      "description": "Build neural models backed by libtorch"
    },
    "ui": {
      "description": "Build ImGui backed tree viewer UI",
      "dependencies": [
        {
          "name": "imgui",
          "default-features": false,
          "features": [
            "docking-experimental",
            "glfw-binding",
            "opengl3-binding"
          ]
        }
      ]
    }
  }
}
